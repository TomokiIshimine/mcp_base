# Streamlit ネイティブ OIDC（st.login / st.user / st.logout）の認証設定テンプレート。
#
# 実体 .streamlit/secrets.toml は VCS 非追跡（.gitignore 済み）。本番／Docker では
# entrypoint（方式 A）が env からこのファイルを生成するため、手で編集する必要はない。
# ローカルでホスト起動（streamlit run）する場合のみ、本ファイルを
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# でコピーし、プレースホルダを実値に置き換える。
#
# 値の供給元（env 変数名）と GCP 側設定:
# - cookie_secret        : OAUTH_COOKIE_SECRET（十分長いランダム文字列。署名鍵）
# - client_id            : OAUTH_GOOGLE_CLIENT_ID（GCP OAuth クライアント ID）
# - client_secret        : OAUTH_GOOGLE_CLIENT_SECRET（同シークレット。秘匿）
# - redirect_uri         : OAUTH_REDIRECT_URI（固定パス /oauth2callback。ホスト部のみ env 供給）
# redirect_uri は GCP「承認済みのリダイレクト URI」に完全一致で登録すること。
# localhost:8501 公開ならローカル / Docker 共通で下記の値になる。

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "REPLACE_WITH_LONG_RANDOM_COOKIE_SECRET"

[auth.google]
client_id = "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID"
client_secret = "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
