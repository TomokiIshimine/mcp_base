# MySQL 接続情報。
# MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE は必須。未設定だと起動時に失敗する
# （弱い既定資格情報での意図せぬ接続を防ぐ fail-fast）。HOST/PORT は未設定なら
# ローカル既定値（127.0.0.1:3306）になる。
#
# 下の MYSQL_HOST=db は Docker Compose 用の値（コンテナ間はサービス名 db で通信）。
# ホストから直接 `streamlit run app.py` で動かす場合は、この .env を使わず HOST を
# 未設定（=既定の 127.0.0.1）にするか、MYSQL_HOST=127.0.0.1 / MYSQL_PORT=3307
# （compose が publish するポート）に書き換えること。用途で host が異なる点に注意。
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app_password
MYSQL_DATABASE=app_db

# ログ出力レベル（DEBUG / INFO / WARNING / ERROR）。未設定時・不正値は INFO。
LOG_LEVEL=INFO
