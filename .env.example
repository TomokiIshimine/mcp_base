# MySQL 接続情報。
# MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE は必須。未設定だと起動時に失敗する
# （弱い既定資格情報での意図せぬ接続を防ぐ fail-fast）。HOST/PORT は未設定なら
# ローカル既定値（127.0.0.1:3306）になる。
#
# 下の MYSQL_HOST=db は Docker Compose 用の値（コンテナ間はサービス名 db で通信）。
# ホストから直接 `streamlit run app.py` で動かす場合は、この .env を使わず HOST を
# 未設定（=既定の 127.0.0.1）にするか、MYSQL_HOST=127.0.0.1 / MYSQL_PORT=3307
# （compose が publish するポート）に書き換えること。用途で host が異なる点に注意。
#
# 本ファイルを `cp .env.example .env` でコピーすると compose が自動読込する。
# docker-compose.yml は資格情報を直書きせずここから補間するため、.env が無いと
# compose 系コマンドは起動時にエラーになる。
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app_password
MYSQL_DATABASE=app_db
# MySQL の root パスワード（db コンテナ初期化・ヘルスチェック用。compose のみで使用）。
MYSQL_ROOT_PASSWORD=root_password

# ログ出力レベル（DEBUG / INFO / WARNING / ERROR）。未設定時・不正値は INFO。
LOG_LEVEL=INFO

# 認証ゲート（OAuth2 / Google）の設定。compose の app サービスに配線され、
# AUTH_ADMIN_EMAIL は infrastructure 設定クラスが直接読む（未設定・空文字なら起動時
# fail-fast、AC-1）。OAUTH_* は entrypoint（docker/render-secrets.sh）が
# .streamlit/secrets.toml の [auth] へレンダリングして Streamlit が読む（方式 A）。
# docker-compose.yml はこれらを `:-`（既定空文字）で補間するため、未設定でも compose
# コマンド自体はエラーにならず（test 等の周辺サービスを巻き添えにしない）。fail-fast は
# app 起動時に発火する: AUTH_ADMIN_EMAIL は AuthConfig.from_env() が ConfigError、
# OAUTH_* は entrypoint render-secrets.sh の必須検査が起動を中止する。
#
# - AUTH_ADMIN_EMAIL          : 認可する管理者の Google アカウント Email（完全一致照合）。
# - OAUTH_GOOGLE_CLIENT_ID    : GCP OAuth クライアント ID。
# - OAUTH_GOOGLE_CLIENT_SECRET: GCP OAuth クライアントシークレット（秘匿）。
# - OAUTH_COOKIE_SECRET       : Cookie 署名鍵（32 文字以上のランダム文字列。秘匿）。
#                               例: `openssl rand -hex 32`。プレースホルダ（REPLACE_WITH_*）
#                               のままや短すぎる値は entrypoint が起動時に拒否する。
# - OAUTH_REDIRECT_URI        : 既定 http://localhost:8501/oauth2callback。GCP の
#                               「承認済みのリダイレクト URI」に完全一致で登録すること。
AUTH_ADMIN_EMAIL=admin@example.com
OAUTH_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID
OAUTH_GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET
OAUTH_COOKIE_SECRET=REPLACE_WITH_LONG_RANDOM_COOKIE_SECRET
OAUTH_REDIRECT_URI=http://localhost:8501/oauth2callback
