# Python virtual environment
.venv/

# Python bytecode caches
__pycache__/
*.pyc

# Test / lint tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage artifacts
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local environment file (実体。.env.example のみ追跡する)
.env

# Streamlit のシークレット実体（[auth] の client_secret / cookie_secret 等を含む）。
# entrypoint が env からレンダリングする生成物のため VCS 非追跡。.example のみ追跡する。
.streamlit/secrets.toml

# Claude Code のローカル設定（マシン固有）
.claude/settings.local.json

# bootstrap ワークフローの作業生成物（設計書・レビュー記録など）
tasks/
